#!/bin/sh
#
# Pre-push identity guard for tempertools/* public repos.
#
# Blocks pushes whose commits are not authored AND committed as
# "Temper <hello@tempertools.com>".
#
#

remote_name="$1"
remote_url="$2"

# Only enforce on tempertools/* remotes. Defensive default: allow otherwise.
case "$remote_url" in
    *tempertools/*) ;;
    *) exit 0 ;;
esac

EXPECTED_NAME="Temper"
EXPECTED_EMAIL="hello@tempertools.com"
ZERO=0000000000000000000000000000000000000000

bad=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # Deletion — no commits to inspect.
    [ "$local_sha" = "$ZERO" ] && continue

    # New branch — inspect all commits reachable from local_sha that aren't
    # already on a remote tracking ref.
    if [ "$remote_sha" = "$ZERO" ]; then
        range="$local_sha --not --remotes"
    else
        range="$remote_sha..$local_sha"
    fi

    # Any commit with non-Temper author OR committer is a fail.
    offenders=$(git log --pretty=format:'%H|%an|%ae|%cn|%ce' $range 2>/dev/null | \
        awk -F'|' -v n="$EXPECTED_NAME" -v e="$EXPECTED_EMAIL" \
        '$2 != n || $3 != e || $4 != n || $5 != e { print }')

    if [ -n "$offenders" ]; then
        echo ""
        echo "  PRE-PUSH BLOCKED: non-Temper identity on $local_ref"
        echo ""
        echo "  Remote: $remote_url"
        echo "  Expected author AND committer: $EXPECTED_NAME <$EXPECTED_EMAIL>"
        echo ""
        echo "  Offending commits (sha | author | author-email | committer | committer-email):"
        echo "$offenders" | sed 's/^/    /'
        echo ""
        echo "  Fix: rebase and reset identity, e.g."
        echo "    git rebase -i <base> --exec \"git commit --amend --no-edit --reset-author\""
        echo "  or cherry-pick the content onto a fresh branch with the correct identity."
        echo ""
        bad=1
    fi
done

[ "$bad" -eq 0 ] || exit 1
exit 0
